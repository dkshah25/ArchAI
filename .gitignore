# .gitignore for ArchAI

# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.Python
.venv/
venv/
env/
ENV/
.eggs/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
*.log

# ──────────────────────────────────────────────
# Environment variables — NEVER commit these
# ──────────────────────────────────────────────
.env
.env.local
.env.*.local
backend/.env

# ──────────────────────────────────────────────
# Database files
# ──────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
backend/archai.db

# ──────────────────────────────────────────────
# Cloned repositories — can be very large
# ──────────────────────────────────────────────
backend/cloned_repos/

# ──────────────────────────────────────────────
# Node.js
# ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm

# ──────────────────────────────────────────────
# Next.js
# ──────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/.vercel

# ──────────────────────────────────────────────
# OS files
# ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────
# IDE & Editor files
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ──────────────────────────────────────────────
# Temporary files
# ──────────────────────────────────────────────
*.tmp
*.temp
tmp/
temp/
