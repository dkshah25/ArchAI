# ──────────────────────────────────────────────
# ArchAI Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to backend/.env and fill in your values.
# Never commit your actual .env file to version control.

# ── Required ──────────────────────────────────
# Google Gemini API Key
# Get yours free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ──────────────────────────────────
# SQLite database file path (relative to backend/)
DATABASE_URL=archai.db

# Allowed CORS origins for the frontend
# Comma-separated list of origins
CORS_ORIGINS=http://localhost:3000

# Maximum repository size to clone (in MB)
MAX_REPO_SIZE_MB=500

# Git clone timeout in seconds
GIT_CLONE_TIMEOUT=120

# Number of files to analyze per repository (0 = unlimited)
MAX_FILES_PER_REPO=0
